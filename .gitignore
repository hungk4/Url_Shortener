## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPS/
[Release]/
[Release]PS/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]/
[L]og/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated file tooltips
-vs-doc.xml

# MSTest test Results
[T]est[R]esults/
[B]uild[L]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent-gc.log

# OpenCover
pdf/

# Output of MSBuild database project generator
*.sqlproj.user

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# User secrets
secrets.json
appsettings.Development.json

# Web tools
node_modules/
bower_components/

# EF Core migrations bundle
efbundle.exe
